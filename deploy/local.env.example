# 无感记账部署配置:cp local.env.example local.env 后填入真实值。
# local.env 已被 .gitignore,密钥不入库;make install-service / install-tunnel 会读取它。
# 注意:值经 sed 注入模板,不要包含 | & 字符(标准 API key / URL 均不含)。

# /api/inbox 的 Bearer 令牌,自己生成一段随机串,如: openssl rand -hex 24
NEVE_INBOX_TOKEN=

# AI 识别:claude 或 gemini
NEVE_AI_PROVIDER=claude
NEVE_AI_API_KEY=
# claude 留空默认 claude-opus-4-8;gemini 必填(与快捷指令现用模型一致)
NEVE_AI_MODEL=

# Bark 推送完整 URL(含 device key),如 https://api.day.app/xxxxxxxx;留空不推送
NEVE_BARK_URL=

# 数据备份:git 远程 URL(建议 SSH 私有库,如 git@github.com:you/neve-data.git)。
# 填了才启用:服务端把账本镜像进 iCloud 外的 git 仓库并推送,做版本历史 + 异地灾备。
# 之所以由服务端做而非 launchd 独立任务:数据在快捷指令 iCloud 容器里,受 TCC 保护,
# 只有已获授权的服务端进程能读;git 直接管该目录会被沙箱拒(readdir/chdir)。
NEVE_BACKUP_REMOTE=
# 镜像仓库位置,留空默认 ~/Library/Application Support/Neve/data-backup
NEVE_BACKUP_DIR=

# Cloudflare Tunnel(make install-tunnel 用):tunnel UUID 与对外域名
NEVE_TUNNEL_ID=
NEVE_TUNNEL_HOSTNAME=
